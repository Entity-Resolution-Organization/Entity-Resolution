# ============================================================
#  Inference Pipeline — Environment Variables
#  Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- GCP Core ---
GCP_PROJECT_ID=entity-resolution-487121
GCP_BUCKET_NAME=entity-resolution-bucket-1
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- Vertex AI ---
# Leave blank — endpoint ID is auto-discovered from GCS endpoint_info.json
# Only set manually if you want to override endpoint discovery
VERTEX_AI_ENDPOINT_ID=

# --- Mock Client Toggle ---
# Set to "true" during development / when Vertex AI endpoint is not live
USE_MOCK_CLIENT=false

# --- API ---
API_BASE_URL=http://localhost:8000

# --- MLflow ---
MLFLOW_TRACKING_URI=http://34.10.100.218:5000

# --- Airflow (shared with Data-Pipeline) ---
AIRFLOW_UID=50000
AIRFLOW_GID=0

# --- Notifications (Step 7 — monitoring) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL=your-team@example.com