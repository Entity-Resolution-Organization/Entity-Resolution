# Data directories (DVC tracked — keep .dvc pointer files in Git)
data/raw/
data/processed/
data/analytics/
data/metrics/
data/training/

# Airflow runtime
airflow.cfg
airflow.db
airflow-webserver.pid
standalone_admin_password.txt
logs/
!logs/.gitkeep

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Build & Distribution
dist/
build/
*.egg-info/