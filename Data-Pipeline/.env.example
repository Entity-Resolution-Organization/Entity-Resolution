# =============================================================================
# Entity Resolution Data Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is gitignored and will not be committed.
# =============================================================================

# Airflow
# Run: echo $(id -u) to get your user ID
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=changeme

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket
DVC_GCS_BUCKET=your-dvc-bucket

# Environment: "local" or "production"
# Controls whether dataset handlers download real data or generate synthetic
ENVIRONMENT=production