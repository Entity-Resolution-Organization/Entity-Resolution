# =============================================================================
# Entity Resolution Data Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is gitignored and will not be committed.
# =============================================================================

# Airflow Configuration
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# =============================================================================
# GCP Configuration (required for cloud mode)
# =============================================================================
# Set these values from your Google Cloud Project

GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket
BQ_DATASET=your-bq-dataset

# =============================================================================
# Execution Mode
# =============================================================================
# "local" - Run locally only, skip GCS/BigQuery uploads (default)
# "cloud" - Upload data to GCS and BigQuery

EXECUTION_MODE=local

# =============================================================================
# Setup Instructions for Cloud Mode:
# =============================================================================
# 1. Create GCP resources (bucket and BigQuery dataset)
# 2. Create a service account with Storage Admin + BigQuery roles
# 3. Download the service account key JSON file
# 4. Place it at: secrets/gcp-sa-key.json
# 5. Set the values above with your project details
# 6. Set EXECUTION_MODE=cloud
# 7. Restart the Docker containers: docker compose down && docker compose up -d
# =============================================================================
