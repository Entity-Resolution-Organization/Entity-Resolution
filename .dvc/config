# DVC (Data Version Control) configuration
# Tracks large data files separately from Git using pointer (.dvc) files
# Location: ENTITY-RESOLUTION/.dvc/config (repo root, alongside .git)
#
# Remote: Google Cloud Storage
# Auth: VM service account (automatic) or `gcloud auth application-default login`
#
# Team setup:
#   pip install dvc[gs]
#   dvc pull                    # downloads latest versioned data

[core]
    # Default remote used by `dvc push` and `dvc pull`
    remote = gcs
    autostage = true

['remote "gcs"']
    # Path to the DVC storage GCS bucket
    # Stores actual data files that are too large for Git
    url = gs://entity-resolution-dvc-bucket